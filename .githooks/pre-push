#!/usr/bin/env bash
# pre-push hook — safety net: regenerate dep graphs if they're stale.
# Normally graphs are kept up to date by the pre-commit hook.
# This hook catches the case where someone bypassed pre-commit (--no-verify).

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
REGEN="$REPO_ROOT/scripts/regen-dep-graphs.sh"

CHANGED_FILES=()

while read local_ref local_sha remote_ref remote_sha; do
  EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
  BASE="${remote_sha:-$EMPTY_TREE}"
  if [[ "$BASE" == "0000000000000000000000000000000000000000" ]]; then
    BASE="$EMPTY_TREE"
  fi

  while IFS= read -r file; do
    CHANGED_FILES+=("$file")
  done < <(git -C "$REPO_ROOT" diff --name-only "$BASE" "$local_sha" 2>/dev/null || true)
done

if [[ ${#CHANGED_FILES[@]} -eq 0 ]]; then
  exit 0
fi

"$REGEN" "${CHANGED_FILES[@]}"

GRAPH_CHANGED=$(git -C "$REPO_ROOT" diff --cached --name-only -- \
  .claude/context/frontend-dep-graph.json \
  .claude/context/backend-dep-graph.json 2>/dev/null || true)

if [[ -n "$GRAPH_CHANGED" ]]; then
  echo "[dep-graph] Graphs were stale — committing update before push..."
  git -C "$REPO_ROOT" commit -m "chore: update dependency graphs [pre-push]" --no-verify
  echo "[dep-graph] Run 'git push' once more to include the graph commit."
  exit 1
fi

exit 0
