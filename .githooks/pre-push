#!/usr/bin/env bash
# pre-push hook — regenerate dep graphs for any changed source files.
#
# Git passes pushed refs on stdin as:
#   <local-ref> <local-sha1> <remote-ref> <remote-sha1>
# We diff local-sha1..remote-sha1 to find exactly what's being pushed.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
REGEN="$REPO_ROOT/scripts/regen-dep-graphs.sh"

CHANGED_FILES=()

while read local_ref local_sha remote_ref remote_sha; do
  # If remote doesn't have this branch yet (new branch), diff against empty tree
  EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
  BASE="${remote_sha:-$EMPTY_TREE}"
  if [[ "$BASE" == "0000000000000000000000000000000000000000" ]]; then
    BASE="$EMPTY_TREE"
  fi

  while IFS= read -r file; do
    CHANGED_FILES+=("$file")
  done < <(git -C "$REPO_ROOT" diff --name-only "$BASE" "$local_sha" 2>/dev/null || true)
done

if [[ ${#CHANGED_FILES[@]} -eq 0 ]]; then
  exit 0
fi

# Run regen only if source files changed
"$REGEN" "${CHANGED_FILES[@]}"

# If graphs were updated and staged, amend them into the push via a new commit
GRAPH_CHANGED=$(git -C "$REPO_ROOT" diff --cached --name-only -- \
  .claude/context/frontend-dep-graph.json \
  .claude/context/backend-dep-graph.json 2>/dev/null || true)

if [[ -n "$GRAPH_CHANGED" ]]; then
  echo "[dep-graph] Committing updated graphs before push..."
  git -C "$REPO_ROOT" commit -m "chore: update dependency graphs [pre-push]" --no-verify
fi

exit 0
